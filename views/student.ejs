<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Student Profile</title>
</head>
<body>
    <!-- Bootstrap Navbar -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/">Student List App</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav">
              <li class="nav-item">
                <a class="nav-link" href="/addStudent">Add new student</a>
              </li> 
            </ul>
          </div>
        </div>
    </nav>
    
    <div class="container mt-4">
        <h2>Student Profile Details</h2>
        <hr>
        <% if (student) { %> 
            <div class="card p-4 shadow-sm" style="max-width: 500px;">
                <p><b>Student ID:</b> <%= student.studentId %></p>
                <p><b>Name:</b> <%= student.name %></p>
                <p><b>Date of Birth:</b> <%= new Date(student.dob).toLocaleDateString() %></p>
                <p><b>Contact Info:</b> <%= student.contact %></p>
                <p><b>Profile Photo:</b></p>
                <img src="<%= student.image %>" class="img-fluid rounded mb-3" style="max-width: 200px;" alt="Profile Picture">
            </div>
        <% } else { %>
            <div class="alert alert-danger">No student record located.</div>
        <% } %>
        <br>
        <a href="/" class="btn btn-primary">Back to List</a>
    </div>
</body>
</html>